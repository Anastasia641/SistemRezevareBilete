@{
    ViewData["Title"] = "Acasă";
}



<!-- Banner Hero -->
<div class="jumbotron text-center text-dark" style="background-image: url('/images/avion_banner.jpg'); background-size: cover; background-position: center; padding: 120px 0;">
    <h1 class="display-4 fw-bold">✈ Bine ai venit la Sistemul de Rezervări Aeriene!</h1>
    <p class="lead">Găsește cele mai bune zboruri pentru vacanța ta sau călătorii de afaceri.</p>
    <a href="/Zbor/Cauta" class="btn btn-primary btn-lg mt-3">Caută un zbor</a>
</div>

<!-- Carduri cu opțiuni -->
<div class="container mt-5">
    <div class="row text-center">
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <img src="/images/cauta_zbor.jpg" class="card-img-top" alt="Caută zbor">
                <div class="card-body">
                    <h5 class="card-title">Caută zbor ✈️</h5>
                    <p class="card-text">Introdu orașul de plecare și destinația pentru a găsi cele mai bune zboruri.</p>
                    <a href="/Zbor/Cauta" class="btn btn-primary">Caută acum</a>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <img src="/images/vezi_rezervari.jpg" class="card-img-top" alt="Vezi rezervările">
                <div class="card-body">
                    <h5 class="card-title">Vezi rezervările 🧳</h5>
                    <p class="card-text">Consultă toate rezervările efectuate și gestionează biletele.</p>
                    <a href="/Zbor/Rezervari" class="btn btn-primary">Vezi rezervările</a>
                </div>
            </div>
        </div>
    </div>
</div>
